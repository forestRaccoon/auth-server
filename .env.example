# ============================================
# Сервер
# ============================================
PORT=                                   # Порт, на котором запускается сервер
FRONTEND_URL=         # URL фронтенда для CORS

# ============================================
# База данных MongoDB
# ============================================
MONGO_URI= # Строка подключения к MongoDB

# ============================================
# JWT токены
# ============================================
JWT_ACCESS_SECRET=         # Секрет для подписи access-токенов
JWT_REFRESH_SECRET=       # Секрет для подписи refresh-токенов
ACCESS_TOKEN_EXPIRES=                    # Время жизни access-токена (пример: 15m, 1h, 2d)
REFRESH_TOKEN_EXPIRES=                    # Время жизни refresh-токена

# ============================================
# Bcrypt (хеширование паролей)
# ============================================
BCRYPT_SALT_ROUNDS=                       # Количество раундов соли для bcrypt

# ============================================
# Валидация: Пароль
# ============================================
PASSWORD_MIN_LENGTH=                       # Минимальная длина пароля
PASSWORD_MAX_LENGTH=                      # Максимальная длина пароля
PASSWORD_REQUIRE_LETTER=                # Требовать хотя бы одну букву
PASSWORD_REQUIRE_NUMBER=                # Требовать хотя бы одну цифру
PASSWORD_REQUIRE_SPECIAL=              # Требовать хотя бы один спецсимвол
PASSWORD_SPECIAL_CHARS=             # Разрешённые спецсимволы (если требуется)

# ============================================
# Валидация: Email
# ============================================
EMAIL_MIN_LENGTH=                          # Минимальная длина email
EMAIL_MAX_LENGTH=                        # Максимальная длина email
EMAIL_REQUIRE_TLD=                      # Требовать наличие доменной зоны (например, .com)

# ============================================
# Валидация: Имя и фамилия
# ============================================
FULLNAME_MIN_LENGTH=                       # Минимальная длина имени/фамилии
FULLNAME_MAX_LENGTH=                      # Максимальная длина имени/фамилии

# ============================================
# Восстановление пароля
# ============================================
RESET_CODE_LENGTH=                         # Длина кода сброса пароля
RESET_CODE_CHARSET=  # Допустимые символы
RESET_CODE_EXPIRES_MINUTES=               # Время действия кода (минуты)

# ============================================
# Дефолтная аватарка
# ============================================
DEFAULT_AVATAR_URL=
# Шаблон URL аватарки по умолчанию. {{email_hash}} заменяется на MD5 от email.

# ============================================
# SMTP (отправка писем)
# ============================================
SMTP_HOST=                   # SMTP сервер
SMTP_PORT=                              # Порт (587 для TLS, 465 для SSL)
SMTP_SECURE=                          # true для SSL (порт 465), false для TLS
SMTP_USER=             # Логин (обычно email)
SMTP_PASS=                # Пароль или app-пароль
SMTP_FROM= # Отправитель

# ============================================
# Rate limiting (ограничение частоты запросов)
# ============================================
THROTTLE_TTL=                            # Интервал сброса счётчика (секунды)
THROTTLE_LIMIT=                          # Максимум запросов за интервал (глобально)

THROTTLE_LOGIN_LIMIT=                     # Лимит попыток входа
THROTTLE_LOGIN_TTL=                     # Интервал для входа (15 минут)

THROTTLE_REGISTER_LIMIT=                  # Лимит регистраций
THROTTLE_REGISTER_TTL=                 # Интервал для регистрации (1 час)

# ============================================
# Подтверждение email
# ============================================
EMAIL_VERIFICATION_EXPIRES_MINUTES=      # Время действия кода верификации (минуты)
EMAIL_VERIFICATION_REQUIRED=           # Требовать подтверждение email перед входом

# ============================================
# CSRF защита
# ============================================
CSRF_SECRET=          # Секрет для сессии CSRF

# ============================================
# Пагинация
# ============================================
DEFAULT_PAGE_LIMIT=                      # Количество записей на страницу по умолчанию
MAX_PAGE_LIMIT=                         # Максимальное количество записей на страницу

# ============================================
# История входов
# ============================================
LOGIN_HISTORY_LIMIT=                     # Сколько последних входов хранить на пользователя
SUSPICIOUS_LOGIN_NOTIFICATION=         # Отправлять письмо при входе с нового устройства

# ============================================
# Загрузка аватарок
# ============================================
AVATAR_UPLOAD_TEMP=          # Временная папка для загрузки
AVATAR_FINAL_DIR=         # Папка для сохранения обработанных аватарок
AVATAR_MAX_SIZE_MB=                       # Максимальный размер файла (МБ)
AVATAR_ALLOWED_MIMES=  # Разрешённые MIME-типы
AVATAR_MAX_DIMENSION=                  # Максимальная ширина/высота (пиксели) — сжатие до этого
AVATAR_THUMB_DIMENSION=                 # Размер миниатюры (квадрат, cover)

# ============================================
# Блокировка аккаунта при неудачных входах
# ============================================
MAX_LOGIN_ATTEMPTS_TEMP=                  # Количество неудачных попыток до временной блокировки
MAX_LOGIN_ATTEMPTS_PERM=                 # Количество неудачных попыток до перманентной блокировки
TEMP_LOCK_MINUTES=                       # Длительность временной блокировки (минуты)

# ============================================
# Graceful shutdown
# ============================================
GRACEFUL_SHUTDOWN_TIMEOUT_MS=         # Таймаут ожидания закрытия соединений (мс)

# ============================================
# Роли по умолчанию
# ============================================
DEFAULT_USER_ROLE=                     # Роль, присваиваемая новому пользователю

# ============================================
# Суперадмин (создаётся при первом запуске)
# ============================================
SUPER_ADMIN_EMAIL=     # Email суперадмина
SUPER_ADMIN_PASSWORD=  # Пароль суперадмина

# ============================================
# Redis (для очередей и кэша)
# ============================================
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=                            # Пароль (если есть)

# ============================================
# Лимиты размера тела запроса
# ============================================
REQUEST_JSON_LIMIT_MB=                    # Максимальный размер JSON (МБ)
REQUEST_URLENCODED_LIMIT_MB=              # Максимальный размер URL-encoded (МБ)

# ============================================
# Удаление аккаунта
# ============================================
DELETION_CODE_EXPIRES_MINUTES=           # Время действия кода удаления (минуты)
SOFT_DELETE_ENABLED=                   # true – мягкое удаление (deletedAt), false – физическое